# Copy to .env and fill in values. Never commit .env.

# ── Réseau & Permissions ──────────────────────────────────────────────────────
TZ=Europe/Paris
PUID=1001
PGID=1001

# ── Chemins ───────────────────────────────────────────────────────────────────
CONFIG_DIR=/opt/media-stack
DATA_DIR=/data

# ── VPN ───────────────────────────────────────────────────────────────────────
WIREGUARD_PRIVATE_KEY=your_wireguard_private_key_here

# ── qBittorrent ───────────────────────────────────────────────────────────────
QB_PASSWORD=your_qbittorrent_password_here

# ── Hygie ─────────────────────────────────────────────────────────────────────
# Chiffrement des clés API sensibles (recommandé en production)
# Générer : python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
HYGIE_ENCRYPTION_KEY=your_fernet_key_here

# Base de données (laisser vide pour SQLite par défaut)
# MariaDB interne  : DATABASE_URL=mysql+aiomysql://hygie:${DB_MARIADB_PASSWORD}@mariadb:3306/hygie
# MariaDB distante : DATABASE_URL=mysql+aiomysql://user:pass@host:3306/hygie
DATABASE_URL=

# MariaDB interne (conteneur séparé, profil mariadb)
DB_MARIADB_PASSWORD=hygie_secret_changez_moi
DB_MARIADB_ROOT_PASSWORD=root_secret_changez_moi

# MariaDB embarquée (tout-en-un, docker-compose.embedded-mariadb.yml)
# Laisser vide = mot de passe auto-généré et stocké dans ./data/.mariadb_pass
EMBEDDED_MARIADB_PASSWORD=

# ── Beszel ────────────────────────────────────────────────────────────────────
Key_Beszel=your_beszel_key_here
Token_Beszel=your_beszel_token_here
