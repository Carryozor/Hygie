# Copy to .env and fill in values. Never commit .env.

# ── Réseau & Permissions ──────────────────────────────────────────────────────
TZ=Europe/Paris
PUID=1001
PGID=1001

# ── Chemins ───────────────────────────────────────────────────────────────────
CONFIG_DIR=/opt/media-stack
DATA_DIR=/data

# ── VPN ───────────────────────────────────────────────────────────────────────
WIREGUARD_PRIVATE_KEY=your_wireguard_private_key_here

# ── qBittorrent ───────────────────────────────────────────────────────────────
QB_PASSWORD=your_qbittorrent_password_here

# ── Hygie ─────────────────────────────────────────────────────────────────────
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
HYGIE_ENCRYPTION_KEY=your_fernet_key_here

# ── Beszel ────────────────────────────────────────────────────────────────────
Key_Beszel=your_beszel_key_here
Token_Beszel=your_beszel_token_here
