# ─── Hygie Environment Variables ─────────────────────────────────────────────
# Copy to .env and set your values. Required = must be set for production.

# ─── Database ─────────────────────────────────────────────────────────────────
DB_PATH=/app/data/hygie.db
# MariaDB (optional) — when set, SQLite is not used
# DATABASE_URL=mysql+aiomysql://hygie:secret@mariadb:3306/hygie

# ─── Security ─────────────────────────────────────────────────────────────────
# [REQUIRED] Fernet key for encrypting API keys/webhooks at rest.
# Generate: python3 -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
HYGIE_ENCRYPTION_KEY=

# [OPTIONAL] JWT signing key — auto-generated if not set (sessions lost on restart)
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# ─── Workers ──────────────────────────────────────────────────────────────────
# [CRITICAL] Must always be 1. See ARCHITECTURE.md for why.
WORKERS=1

# ─── Reverse proxy ────────────────────────────────────────────────────────────
# Set to 1 only when behind a trusted reverse proxy that sets X-Forwarded-For
HYGIE_TRUST_PROXY=0
# CORS allowed origins (comma-separated). Defaults to * when not set.
# HYGIE_ALLOWED_ORIGINS=https://hygie.mydomain.com

# ─── Overlays ─────────────────────────────────────────────────────────────────
# Custom font path for poster overlays (auto-detected on Debian/Ubuntu/Alpine)
# HYGIE_FONT_PATH=/usr/share/fonts/TTF/DejaVuSans-Bold.ttf
